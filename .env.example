NODE_ENV=development
PORT=8000
HOST_PORT=8000

# Postgres (consumed by docker-compose to provision the db container)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=chai_forms

# Use `localhost` for local dev, `postgresdb` (the compose service name) when running in Docker.
# In docker-compose this var is overridden to point at the postgresdb service automatically.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/chai_forms

NEXT_PUBLIC_API_URL=http://localhost:8000/trpc
BASE_URL=http://localhost:8000

JWT_SECRET=your_jwt_secret

FRONTEND_URL=http://localhost:3000
